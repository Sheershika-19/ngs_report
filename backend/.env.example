# Copy this file to ".env" in this folder (backend/). The API loads .env automatically.
# FASTQC_DIR must be the root of your cloned FastQC repo (folder with bin/, sam-*.jar, jbzip2-*.jar).
FASTQC_DIR=C:\Users\DELL\Desktop\FastQC

# Optional: override classpath if jar names differ (Windows use ; between entries)
# FASTQC_CLASSPATH=bin;sam-1.103.jar;jbzip2-0.9.jar

# Optional: heap for FastQC JVM (default 250m)
# FASTQC_JAVA_MEM=250m

# PORT=8787

# Alignment (BWA / samtools): on Windows the API runs shell commands via WSL (wsl.exe)
# using bash -ilc so your interactive Conda/PATH from ~/.bashrc is applied.
# Set to 0 or false only if bwa and samtools are on PATH without WSL (unusual on Windows).
# ALIGN_USE_WSL=1

# If bwa/samtools still are not found (e.g. Conda only in a profile conda hook), add one line
# that runs before the pipeline (no newlines in the value; use && between commands):
# ALIGN_WSL_PROLOGUE=source $HOME/miniconda3/etc/profile.d/conda.sh && conda activate base
