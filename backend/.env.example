# Copy this file to ".env" in this folder (backend/). The API loads .env automatically.
# FASTQC_DIR must be the root of your cloned FastQC repo (folder with bin/, sam-*.jar, jbzip2-*.jar).
FASTQC_DIR=C:\Users\DELL\Desktop\FastQC

# Optional: override classpath if jar names differ (Windows use ; between entries)
# FASTQC_CLASSPATH=bin;sam-1.103.jar;jbzip2-0.9.jar

# Optional: heap for FastQC JVM (default 250m)
# FASTQC_JAVA_MEM=250m

# PORT=8787
