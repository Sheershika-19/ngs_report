# Copy this file to ".env" in this folder (backend/). The API loads .env automatically.
# FASTQC_DIR must be the root of your cloned FastQC repo (folder with bin/, sam-*.jar, jbzip2-*.jar).
FASTQC_DIR=C:\Users\DELL\Desktop\FastQC

# Optional: override classpath if jar names differ (Windows use ; between entries)
# FASTQC_CLASSPATH=bin;sam-1.103.jar;jbzip2-0.9.jar

# Optional: heap for FastQC JVM (default 250m)
# FASTQC_JAVA_MEM=250m

# PORT=8787

# BBMap BBDuk (read trimming): runs bbduk.sh from this folder via Git Bash on Windows.
# Example: BBMAP_DIR=C:\Users\DELL\Downloads\BBMap_39.01\bbmap

# Optional: path to bash.exe if Git is not under Program Files (Windows only)
# GIT_BASH=C:\Program Files\Git\bin\bash.exe

# Alignment (BWA / samtools): on Windows the API runs shell commands via WSL (wsl.exe)
# using bash -ilc so your interactive Conda/PATH from ~/.bashrc is applied.
# Set to 0 or false only if bwa and samtools are on PATH without WSL (unusual on Windows).
# ALIGN_USE_WSL=1

# If bwa/samtools still are not found (e.g. Conda only in a profile conda hook), add one line
# that runs before the pipeline (no newlines in the value; use && between commands):
# ALIGN_WSL_PROLOGUE=source $HOME/miniconda3/etc/profile.d/conda.sh && conda activate base

# Picard MarkDuplicates (Broad toolkit — NOT MusicBrainz Picard):
# On WSL, bare `picard` can launch Windows MusicBrainz Picard (wrong app). Prefer java -jar:
# PICARD_JAVA=/usr/lib/jvm/java-17-openjdk-amd64/bin/java
# PICARD_JAR=~/picard.jar
# Optional JVM args (omit for minimal `java -jar` like your terminal):
# PICARD_JAVA_OPTS=-Xmx4g
# If you do not set PICARD_JAR, the API falls back to the Linux binary:
# PICARD_CMD=/usr/bin/picard

# GATK HaplotypeCaller: java -jar … (uses PICARD_JAVA above). Default jar path if body omits gatkJar:
# GATK_JAR=~/gatk-4.5.0.0/gatk-package-4.5.0.0-local.jar
# Optional: GATK_JAVA_OPTS=-Xmx8g

# Ensembl VEP: wrap with conda so Perl modules (e.g. DBI) match your env:
# VEP_CONDA_ENV=vep_env
# VEP_CMD=vep
# CONDA_EXE=~/miniconda3/bin/conda
# If DBI.pm is still missing in WSL: conda activate vep_env && conda install -y -c bioconda perl-dbi

# CIViC downstream report generator (python vcf_report_generator.py <input.vcf> --output <report.html>)
# Recommended layout:
#   backend/tools/civic_report/vcf_report_generator.py
#   backend/tools/civic_report/civic_chroma_db/
# Then set:
# CIVIC_REPORT_DIR=D:\automated_ngs\backend\tools\civic_report
#
# Optional explicit overrides instead of CIVIC_REPORT_DIR:
# CIVIC_REPORT_SCRIPT=D:\automated_ngs\backend\tools\civic_report\vcf_report_generator.py
# CIVIC_CHROMA_DB_DIR=D:\automated_ngs\backend\tools\civic_report\civic_chroma_db
#
# Optional Python executable override:
# PYTHON_BIN=python
